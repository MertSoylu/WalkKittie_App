    <!-- Settings -->
    <string name="settings_privacy_policy">Privacy Policy</string>
    <string name="privacy_policy_content">Walkkittie Privacy Policy\n\nThis app allows users to track their physical activities to care for a virtual pet. Your privacy is important to us:\n\n1. Activity Tracking: Our app uses your device\'s sensors to count your steps. This data is only used for in-game mechanics.\n\n2. Health Connect: Optionally, we can integrate with Health Connect. This data is processed only on your device and not transferred to external servers.\n\n3. Ads: Our app uses AdMob ads. These services may use device identifiers to show personalized ads.\n\n4. Data Storage: Your personal data is not stored on our servers; all progress is kept locally on your device.\n\nFor more information, you can check Google\'s Privacy Policy:</string>
    <string name="url_google_privacy_policy">https://policies.google.com/privacy</string>

    <!-- Tutorial -->
    <string name="tutorial_home_welcome_title">Welcome to Walkkittie! 🐱</string>
    <string name="tutorial_home_welcome_desc">With this app, you\'ll take care of your virtual cat while tracking your walks. Your steps turn into energy and make your cat happy!</string>
    <string name="tutorial_home_cat_title">Meet Your Cat 😺</string>
